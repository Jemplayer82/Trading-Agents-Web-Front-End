# Cleo daemon environment.
#
# Copy to /etc/cleo/cleo.env on the host, fill in the token, then lock it down:
#   sudo install -D -m 600 deploy/cleo/cleo.env.example /etc/cleo/cleo.env
#   sudo $EDITOR /etc/cleo/cleo.env
#
# Never commit the real token — this .example file carries placeholders only.

# Internal switchboard, reached from the host via the published port (compose
# maps 3109:3107). Do NOT append /mcp — the daemon adds it.
SWITCHBOARD_URL=http://127.0.0.1:3109

# Must match the stack's SWITCHBOARD_MCP_TOKEN (the only gate on the bus port).
SWITCHBOARD_MCP_TOKEN=replace-with-stack-token

# --- Optional ----------------------------------------------------------------
# Bus agent id to register as. Keep "cleo" unless you run more than one.
SWITCHBOARD_AGENT_ID=cleo
# Fallback model when a request doesn't specify one.
DEFAULT_MODEL=claude-sonnet-4-6
# Hard per-call deadline (seconds). Keep below the analysis client's 180s so
# Cleo reports its own timeout before the requester gives up.
CLEO_CALL_TIMEOUT_S=150
# Path to the claude binary if it isn't on PATH for the service user.
# CLAUDE_BIN=/usr/local/bin/claude
# Single-instance lock file (defaults to /tmp/cleo-<agent_id>.lock).
# CLEO_LOCK_FILE=/run/cleo-cleo.lock
