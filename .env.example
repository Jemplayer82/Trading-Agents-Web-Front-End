# ============================================================
# TradingAgents — environment variable reference
# Usage: cp .env.example .env  →  fill in secrets  →  docker compose up -d
# ============================================================

# ------------------------------------------------------------
# LLM
# ------------------------------------------------------------
# Base URL for the Ollama-compatible inference endpoint.
OLLAMA_BASE_URL=https://ollama.com/v1
# API key for the Ollama endpoint (leave blank if your server needs none).
OLLAMA_API_KEY=

# ------------------------------------------------------------
# Schwab brokerage API
# ------------------------------------------------------------
# OAuth app key from developer.schwab.com.
SCHWAB_APP_KEY=
# OAuth app secret from developer.schwab.com.
SCHWAB_APP_SECRET=
# OAuth callback URL registered with Schwab (must match exactly).
SCHWAB_CALLBACK_URL=https://trading.example.com/api/schwab/callback
# 32-byte base64 key used to encrypt stored OAuth tokens at rest.
# Generate: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
TOKEN_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Email / Newsletter
# ------------------------------------------------------------
# SMTP server hostname (e.g. smtp.sendgrid.net, smtp.gmail.com).
SMTP_HOST=
# SMTP port — 587 (STARTTLS) is the typical default.
SMTP_PORT=587
# SMTP authentication username.
SMTP_USER=
# SMTP authentication password or API key.
SMTP_PASS=
# From address used in outbound newsletter emails.
NEWSLETTER_FROM=
# Recipient address(es) for the nightly newsletter.
NEWSLETTER_TO=

# ------------------------------------------------------------
# Notifications
# ------------------------------------------------------------
# Webhook URL for FRED (Federal Reserve) economic-data alerts.
FRED_NOTIFY_URL=

# ------------------------------------------------------------
# Dashboard
# ------------------------------------------------------------
# Public-facing URL of the dashboard — embedded in newsletter links.
DASHBOARD_URL=https://trading.example.com

# ------------------------------------------------------------
# Agent message bus (mcp-switchboard)
# ------------------------------------------------------------
# Generate a token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SWITCHBOARD_MCP_TOKEN=
# Bus mirroring: analysis (default — mirror interactive analyses) | off
BUS_MIRROR=analysis
