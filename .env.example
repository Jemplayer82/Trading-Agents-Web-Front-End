# ============================================================
# TradingAgents — environment variable reference
# Usage: cp .env.example .env  →  fill in secrets  →  docker compose up -d
# For Portainer edge deployments these are entered as stack environment variables, not a .env file.
# ============================================================

# ------------------------------------------------------------
# LLM
# ------------------------------------------------------------
# Base URL for the Ollama-compatible inference endpoint.
# Leave unset for a local Ollama at http://localhost:11434/v1 (the app's fallback).
OLLAMA_BASE_URL=https://ollama.com/v1
# API key for the Ollama endpoint (leave blank if your server needs none).
OLLAMA_API_KEY=

# ------------------------------------------------------------
# Schwab brokerage API
# ------------------------------------------------------------
# OAuth app key from developer.schwab.com.
SCHWAB_APP_KEY=
# OAuth app secret from developer.schwab.com.
SCHWAB_APP_SECRET=
# OAuth callback URL registered with Schwab (must match exactly).
SCHWAB_CALLBACK_URL=https://trading.example.com/api/schwab/callback
# Schwab MCP server that serves live holdings/quotes. Use a host the app containers
# can actually reach (a LAN IP, not a Tailscale IP — Docker bridges can't route those).
# Also settable from the dashboard Settings tab (DB value overrides this env var).
SCHWAB_MCP_URL=http://mcp-schwab:3105/mcp
# 32-byte base64 key used to encrypt stored OAuth tokens at rest.
# Generate: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
TOKEN_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Email / Newsletter
# ------------------------------------------------------------
# SMTP server hostname (e.g. smtp.sendgrid.net, smtp.gmail.com).
SMTP_HOST=
# SMTP port — 587 (STARTTLS) is the typical default.
SMTP_PORT=587
# SMTP authentication username.
SMTP_USER=
# SMTP authentication password or API key.
SMTP_PASS=
# From address used in outbound newsletter emails.
NEWSLETTER_FROM=
# Recipient address(es) for the nightly newsletter.
NEWSLETTER_TO=

# ------------------------------------------------------------
# Notifications
# ------------------------------------------------------------
# Webhook for push alerts (delivered by Fred, the OpenClaw runner — e.g. WhatsApp).
# POSTed as {"text","link"}. Used for scan-start/Schwab-health alerts AND run-failure
# alerts (analysis / portfolio / S&P 500). Run failures ALSO email via the SMTP block
# above (NEWSLETTER_TO). Leave blank to disable the webhook channel.
FRED_NOTIFY_URL=

# Stuck-run reaper (web/scheduler.py): a run whose worker crashed never flips to
# 'failed' on its own. The reaper fails + alerts any scan with no progress for
# STUCK_SCAN_STALL_MIN minutes, or any analysis still 'running' past
# STUCK_ANALYSIS_MIN minutes. Defaults are generous so a slow-but-healthy deep dive
# isn't killed; lower them if your runs are quick.
STUCK_SCAN_STALL_MIN=60
STUCK_ANALYSIS_MIN=90

# ------------------------------------------------------------
# Dashboard
# ------------------------------------------------------------
# Public-facing URL of the dashboard — embedded in newsletter links.
DASHBOARD_URL=https://trading.example.com

# ------------------------------------------------------------
# Agent message bus (mcp-switchboard) — optional, powers the live Agent Bus feed
# ------------------------------------------------------------
# Internal URL of the switchboard container. Defaults to the compose service name;
# the bus stays disabled unless both this and the token are set.
SWITCHBOARD_URL=http://switchboard:3107
# Generate a token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SWITCHBOARD_MCP_TOKEN=
# Bus mirroring: analysis (default — mirror interactive analyses) | off
BUS_MIRROR=analysis
# Switchboard LLM routing (set the dashboard provider to "switchboard" to use it).
# Which bus agent handles llm_request DMs, and which backend it dispatches to
# (blank/ollama, openai, xai, grok, deepseek, or claude). Optional — sane defaults.
SWITCHBOARD_TARGET_AGENT=llm-router
SWITCHBOARD_PROVIDER=
# llm-router daemon: concurrent worker cap, and the bus agent id that "claude"
# requests are forwarded to. Optional.
LLM_ROUTER_CONCURRENCY=8
CLAUDE_AGENT_ID=claude-code

# ------------------------------------------------------------
# Internal service auth
# ------------------------------------------------------------
# Shared secret for inter-container calls (scheduler -> api/portfolio) and to
# bypass the dashboard login on /api routes via the X-Internal-Token header.
# Fail-closed: if unset, the internal-token path is disabled.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_TOKEN=

# ============================================================
# App-level / local CLI (not used by docker-compose templating)
# ============================================================

# ------------------------------------------------------------
# LLM provider API keys
# Set the key for whichever provider(s) you use.
# Consumed via PROVIDER_API_KEY_ENV (tradingagents/llm_clients/api_key_env.py).
# The CLI also writes these to .env when you configure a provider (cli/utils.py).
# ------------------------------------------------------------
OPENAI_API_KEY=
# Optional OpenAI-compatible endpoint override for the llm-router service
# (docker-compose tradingagents-llm-router). Empty = api.openai.com.
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=

# ------------------------------------------------------------
# DEFAULT_CONFIG overrides
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# ------------------------------------------------------------
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
